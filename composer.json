{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "hashids/hashids": "^5.0",
        "intervention/image": "^3.11",
        "lab404/laravel-impersonate": "^1.7",
        "laravel/framework": "^12.0",
        "laravel/mcp": "^v0.5.3",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.14",
        "laravel/socialite": "^5.23",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.5",
        "league/flysystem-aws-s3-v3": "^3.28",
        "livewire/livewire": "^4.0",
        "spatie/laravel-permission": "^6.9",
        "prism-php/prism": "^0.99.0",
        "prism-php/relay": "^1.3",
        "tinymce/tinymce": "^8.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.0",
        "google/apiclient": "^2.18",
        "halestar/fablms-google-integrator": "@dev",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^12.5.8",
        "tomasvotruba/lines": "^1.2"
    },
    "repositories": [
      {
        "type": "path",
        "url" : "../packages/halestar/FabLmsGoogleIntegrator"
      }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": ["app/Utilities/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "halestar\\FabLmsGoogleIntegrator\\": "../packages/halestar/FabLmsGoogleIntegrator/src"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "post-install-cmd": [
            "chmod -R 755 bootstrap\/cache",
            "php artisan optimize:clear",
            "php artisan optimize"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
